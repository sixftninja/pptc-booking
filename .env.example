# Copy this file to `.env` and fill in the blanks below.
# `.env` is gitignored — never commit it.

# PPTC member portal credentials
PPTC_EMAIL=
PPTC_PASSWORD=

# Your full name exactly as it appears in the Attendee dropdown of the booking modal
PPTC_ATTENDEE_NAME=

# Email used for notifications. Sender and recipient can be the same address.
NOTIFY_EMAIL=
NOTIFY_EMAIL_FROM=

# Gmail App Password for the sender (16 characters, no spaces)
NOTIFY_EMAIL_PASSWORD=

# CapSolver API key (https://capsolver.com)
CAPSOLVER_API_KEY=

# --- Test / simulator overrides --------------------------------------------
# Leave blank in production. Set when running against the local simulator.
MOCK_URL=
CAPSOLVER_MOCK_URL=
TEST_MODE=
